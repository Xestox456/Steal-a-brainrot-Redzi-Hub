local IMAGE_URL = "https://raw.githubusercontent.com/hesiz/Images/refs/heads/main/sob.jpg"
local IMAGE_FILE = "sob_icon.jpg"

local function downloadImage()
    if not isfile(IMAGE_FILE) then
        local res = request({ Url = IMAGE_URL, Method = "GET" })
        if res and res.StatusCode == 200 then
            writefile(IMAGE_FILE, res.Body)
        end
    end
    return getcustomasset(IMAGE_FILE)
end

